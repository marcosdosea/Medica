@using Core.Dto.Paciente
@model PacienteDetailsDto

@{
    ViewData["Title"] = "Detalhes do Paciente";
}

<div class="content-container">
    <div class="header-inline mb-4">
        <a asp-action="Index" class="btn-voltar">
            <i class="fas fa-arrow-left"></i>
        </a>
        <h2 style="margin: 0; font-weight: bold; font-size: 26px;">Detalhes do paciente</h2>
    </div>

    <div class="row">
        <div class="col-12">
            <div class="secao-header" style="border:none; margin-top:0; margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                <i class="fas fa-user" style="color: var(--text-muted); font-size: 20px;"></i>
                <span style="font-weight: 700; color: var(--text-muted); font-size: 20px;">Sobre</span>
            </div>

            <div class="row">
                <div class="col-lg-9 col-md-8 col-12 form-group-custom">
                    <label class="label-custom">Nome</label>
                    <div class="form-control-static">@Model.Nome</div>
                </div>
                <div class="col-lg-3 col-md-4 col-12 form-group-custom">
                    <label class="label-custom">Data de nascimento</label>
                    <div class="form-control-static">@(Model.DataNascimento.HasValue ? Model.DataNascimento.Value.ToString("dd/MM/yyyy") : "--")</div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 col-12 form-group-custom">
                    <label class="label-custom">CPF</label>
                    <div class="form-control-static">@Model.Cpf</div>
                </div>
                <div class="col-md-8 col-12 form-group-custom">
                    <label class="label-custom">Cartão SUS</label>
                    <div class="form-control-static">@(string.IsNullOrEmpty(Model.CartaoSus) ? "--" : Model.CartaoSus)</div>
                </div>
            </div>

            <div class="row align-items-end">
                <div class="col-xl-3 col-lg-6 col-md-12 col-12 form-group-custom">
                    <label class="label-custom">Alergia a medicamentos?</label>
                    <div class="form-control-static">@(Model.AlergiaMedicamento == 1 ? "Sim" : "Não")</div>
                </div>
                <div class="col-xl-2 col-lg-6 col-md-12 col-12 form-group-custom">
                    <label class="label-custom">Tipo sanguíneo</label>
                    <div class="form-control-static">@Html.DisplayFor(model => model.TipoSanguineo)</div>
                </div>
                <div class="col-xl-2 col-lg-4 col-md-4 col-6 form-group-custom">
                    <label class="label-custom">Peso</label>
                    <div class="form-control-static">@(Model.Peso > 0 ? Model.Peso.ToString() + " kg" : "--")</div>
                </div>
                <div class="col-xl-2 col-lg-4 col-md-4 col-6 form-group-custom">
                    <label class="label-custom">Altura</label>
                    <div class="form-control-static">@(Model.Altura > 0 ? Model.Altura.ToString() + " m" : "--")</div>
                </div>
                <div class="col-xl-3 col-lg-4 col-md-4 col-12 form-group-custom">
                    <label class="label-custom">Sexo</label>
                    <div class="form-control-static">@(Model.Sexo == "M" ? "Masculino" : Model.Sexo == "F" ? "Feminino" : "--")</div>
                </div>
            </div>

            <div class="row align-items-end">
                <div class="col-xl-3 col-lg-6 col-md-12 col-12 form-group-custom">
                    <label class="label-custom">Possui deficiência?</label>
                    <div class="form-control-static">@(Model.PossuiDeficiencia == 1 ? "Sim" : "Não")</div>
                </div>
                <div class="col-xl-2 col-lg-6 col-md-6 col-12 form-group-custom">
                    <label class="label-custom">Parentesco</label>
                    <div class="form-control-static">@(Model.Vinculo?.Parentesco ?? "--")</div>
                </div>
                <div class="col-xl-3 col-lg-6 col-md-6 col-12 form-group-custom">
                    <label class="label-custom">Apelido</label>
                    <div class="form-control-static">@(string.IsNullOrEmpty(Model.Apelido) ? "--" : Model.Apelido)</div>
                </div>
                <div class="col-xl-4 col-lg-6 col-md-12 col-12 form-group-custom">
                    <label class="label-custom">Escolaridade</label>
                    <div class="form-control-static" style="white-space: nowrap;">
                        @(Model.Escolaridade == "SuperiorIncompleto" ? "Superior Incompleto" :
                          Model.Escolaridade == "SuperiorCompleto" ? "Superior Completo" :
                          Model.Escolaridade == "MedioCompleto" ? "Médio Completo" : Model.Escolaridade?.ToString() ?? "--")
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.AlergiaMedicamento == 1 && Model.Alergias != null && Model.Alergias.Any())
    {
        <div class="row mb-0 mt-2">
            <div class="col-12">
                <div class="secao-header" style="border:none; margin-top:10px; margin-bottom: 10px; display: flex; align-items: center; gap: 10px;">
                    <span style="font-weight: 700; color: var(--text-muted); font-size: 20px;">
                        <i class="fas fa-chevron-down" style="font-size: 14px; margin-right: 4px; color: var(--text-muted); vertical-align: middle;"></i> Alergias - @Model.Alergias.Count.ToString()
                    </span>
                </div>

                <div class="row">
                    @for (int i = 0; i < Model.Alergias.Count; i++)
                    {
                        var alergia = Model.Alergias[i];

                        <div class="col-12 mb-4">
                            <div class="row align-items-end">
                                <div class="col-xl-3 col-lg-4 col-md-5 col-sm-6 col-12 form-group-custom">
                                    <label class="label-custom">Tipo</label>
                                    <div class="form-control-static" style="white-space: nowrap;">@alergia.Tipo.ToString()</div>
                                </div>

                                @if (!string.IsNullOrEmpty(alergia.MedicamentoNome))
                                {
                                    <div class="col-xl-9 col-lg-8 col-md-7 col-sm-6 col-12 form-group-custom">
                                        <label class="label-custom">Medicamento</label>
                                        <div class="form-control-static" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@alergia.MedicamentoNome</div>
                                    </div>
                                }
                            </div>

                            <div class="row">
                                <div class="col-12 form-group-custom">
                                    <label class="label-custom">Descrição</label>
                                    <div class="form-control-static text-wrap" style="min-height: 120px; align-items: flex-start; padding-top: 14px; display: flex; width: 100%; word-break: break-word;">
                                        @alergia.Descricao
                                    </div>
                                </div>
                            </div>

                            @if (i < Model.Alergias.Count - 1)
                            {
                                <hr style="border-color: var(--border); margin-top: 5px; margin-bottom: 5px;" />
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (Model.PossuiDeficiencia == 1 && Model.Deficiencias != null && Model.Deficiencias.Any())
    {
        <div class="row mb-3 mt-0">
            <div class="col-12">
                <div class="secao-header" style="border:none; margin-top:5px; margin-bottom: 10px; display: flex; align-items: center; gap: 10px;">
                    <span style="font-weight: 700; color: var(--text-muted); font-size: 20px;">
                        <i class="fas fa-chevron-down" style="font-size: 14px; margin-right: 4px; color: var(--text-muted); vertical-align: middle;"></i> Deficiências - @Model.Deficiencias.Count.ToString()
                    </span>
                </div>

                <div class="row">
                    @for (int i = 0; i < Model.Deficiencias.Count; i++)
                    {
                        var deficiencia = Model.Deficiencias[i];

                        <div class="col-12 mb-4">
                            <div class="row">
                                <div class="col-12 form-group-custom">
                                    <label class="label-custom">Descrição</label>
                                    <div class="form-control-static text-wrap" style="min-height: 120px; align-items: flex-start; padding-top: 14px; display: flex; width: 100%; word-break: break-word;">
                                        @deficiencia.Descricao
                                    </div>
                                </div>
                            </div>

                            @if (i < Model.Deficiencias.Count - 1)
                            {
                                <hr style="border-color: var(--border); margin-top: 5px; margin-bottom: 5px;" />
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <div class="row mt-3">
        <div class="col-12">
            <div class="secao-header" style="border:none; margin-top:0; margin-bottom: 15px; display: flex; align-items: center; gap: 10px;">
                <i class="fas fa-map-marker-alt" style="color: var(--text-muted); font-size: 20px;"></i>
                <span style="font-weight: 700; color: var(--text-muted); font-size: 20px;">Endereço</span>
            </div>

            <div class="row align-items-end">
                <div class="col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12 form-group-custom">
                    <label class="label-custom">CEP</label>
                    <div class="form-control-static">@Model.Cep</div>
                </div>
                <div class="col-xl-5 col-lg-5 col-md-8 col-sm-12 col-12 form-group-custom">
                    <label class="label-custom">Rua</label>
                    <div class="form-control-static">@Model.Rua</div>
                </div>
                <div class="col-xl-5 col-lg-4 col-md-12 col-sm-12 col-12 form-group-custom">
                    <label class="label-custom">Bairro</label>
                    <div class="form-control-static">@Model.Bairro</div>
                </div>
            </div>

            <div class="row align-items-end">
                <div class="col-xl-2 col-lg-3 col-md-4 col-sm-12 col-12 form-group-custom">
                    <label class="label-custom">Identificador</label>
                    <div class="form-control-static">@Model.Identificador</div>
                </div>
                <div class="col-xl-4 col-lg-4 col-md-5 col-sm-8 col-12 form-group-custom">
                    <label class="label-custom">Cidade</label>
                    <div class="form-control-static">@Model.Cidade</div>
                </div>
                <div class="col-xl-2 col-lg-1 col-md-3 col-sm-4 col-12 form-group-custom">
                    <label class="label-custom">Estado</label>
                    <div class="form-control-static">@Model.Estado</div>
                </div>
                <div class="col-xl-4 col-lg-4 col-md-12 col-sm-12 col-12 form-group-custom">
                    <label class="label-custom">Complemento</label>
                    <div class="form-control-static">@(string.IsNullOrEmpty(Model.Complemento) ? "--" : Model.Complemento)</div>
                </div>
            </div>
        </div>
    </div>

    <div class="actions-container">
        <form method="post" style="display: inline; margin: 0;">
            @Html.AntiForgeryToken()

            @if (Model.Ativo == "S")
            {
                <button type="submit" asp-action="Delete" asp-route-id="@Model.Id" class="btn-med btn-med-danger">Excluir</button>
            }
            else
            {
                <button type="submit" asp-action="Activate" asp-route-id="@Model.Id" class="btn-med btn-med-success">Ativar</button>
            }
        </form>
        <button asp-action="Edit" asp-route-id="@Model.Id" class="btn-med btn-med-primary">Editar</button>
    </div>
</div>