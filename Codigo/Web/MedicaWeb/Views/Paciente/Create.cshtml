@using Core.Enums
@model Core.Dto.PacienteDetailsDto

@{
    ViewData["Title"] = "Cadastrar Paciente";
}

@section Styles {
    <link rel="stylesheet" href="~/css/form/formPaciente.css" asp-append-version="true" />
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="cadastro-page-container">

    <div class="cadastro-header">
        <a asp-action="Index"><i class="bi bi-arrow-left"></i></a>
        <h2>Cadastro de paciente</h2>
    </div>

    <form asp-action="Create" method="post" enctype="multipart/form-data">

        <input type="hidden" asp-for="AlergiaMedicamento" id="AlergiaMedicamentoHidden" value="0" />
        <input type="hidden" asp-for="PossuiDeficiencia" id="PossuiDeficienciaHidden" value="1" />

        <div class="form-section">
            <div class="section-title">
                <i class="bi bi-person-fill"></i> Sobre
            </div>

            <div class="form-row">
                <div class="form-group-custom c-9">
                    <label asp-for="Nome">Nome</label>
                    <input asp-for="Nome" class="form-input-custom" required />
                    <span asp-validation-for="Nome" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
                <div class="form-group-custom c-3">
                    <label asp-for="DataNascimento">Data de nascimento</label>
                    <div style="position: relative;">
                        <input asp-for="DataNascimento" type="date" class="form-input-custom" required />
                    </div>
                    <span asp-validation-for="DataNascimento" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group-custom c-4">
                    <label asp-for="Cpf">CPF</label>
                    <input asp-for="Cpf" class="form-input-custom" placeholder="000.000.000-00" required />
                    <span asp-validation-for="Cpf" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
                <div class="form-group-custom c-8">
                    <label asp-for="CartaoSus">Cartão SUS</label>
                    <input asp-for="CartaoSus" class="form-input-custom" />
                    <span asp-validation-for="CartaoSus" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="switch-container c-3">
                    <label>Alergia a medicamentos?</label>
                    <div class="switch-wrapper">
                        <div class="form-check form-switch p-0 m-0">
                            <input class="form-check-input" type="checkbox" id="switchAlergia" onchange="toggleAlergiaBlock()">
                        </div>
                        <span class="switch-label-text" id="txtAlergia">Não</span>
                    </div>
                </div>

                <div class="form-group-custom c-2">
                    <label asp-for="TipoSanguineo">Tipo sanguíneo</label>
                    <select asp-for="TipoSanguineo" class="form-input-custom"
                            asp-items="Html.GetEnumSelectList<TipoSanguineo>()" required>
                        <option value="">Selecionar</option>
                    </select>
                    <span asp-validation-for="TipoSanguineo" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>

                <div class="form-group-custom c-2">
                    <label asp-for="Peso">Peso</label>
                    <input asp-for="Peso" type="text" class="form-input-custom" placeholder="--" />
                    <span asp-validation-for="Peso" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>

                <div class="form-group-custom c-2">
                    <label asp-for="Altura">Altura</label>
                    <input asp-for="Altura" type="text" class="form-input-custom" placeholder="--" />
                    <span asp-validation-for="Altura" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>

                <div class="form-group-custom c-3">
                    <label asp-for="Sexo">Sexo</label>
                    <select asp-for="Sexo" class="form-input-custom" asp-items="Html.GetEnumSelectList<Sexo>()" required>
                        <option value="">Selecionar</option>
                    </select>
                    <span asp-validation-for="Sexo" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="switch-container c-3">
                    <label>Possui alguma deficiência?</label>
                    <div class="switch-wrapper">
                        <div class="form-check form-switch p-0 m-0">
                            <input class="form-check-input" type="checkbox" id="switchDeficiencia" checked onchange="toggleDeficienciaBlock()">
                        </div>
                        <span class="switch-label-text" id="txtDeficiencia">Sim</span>
                    </div>
                </div>

                <div class="form-group-custom c-2">
                    <label>Parentesco</label>
                    <input type="text" class="form-input-custom" />
                </div>

                <div class="form-group-custom c-4">
                    <label asp-for="Apelido">Apelido</label>
                    <input asp-for="Apelido" class="form-input-custom" />
                    <span asp-validation-for="Apelido" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>

                <div class="form-group-custom c-3">
                    <label asp-for="Escolaridade">Escolaridade</label>
                    @* CORRIGIDO: Adicionado asp-for="Escolaridade" *@
                    <select asp-for="Escolaridade" class="form-input-custom" asp-items="Html.GetEnumSelectList<Escolaridade>()" required>
                        <option value="">Selecionar</option>
                    </select>
                    <span asp-validation-for="Escolaridade" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
            </div>

            <div class="form-row" style="margin-top: 15px;">
                <div class="form-group-custom c-12">
                    <label>Foto</label>
                    <button type="button" class="btn-upload-foto" onclick="document.getElementById('FotoInput').click()">
                        <span id="nomeArquivoFoto">Imagem.png</span>
                        <i class="bi bi-arrow-up-circle-fill"></i>
                    </button>
                    <input type="file" id="FotoInput" name="Foto" accept="image/*" style="display: none;" onchange="actualizarNomeFoto(this)" />
                </div>
            </div>
        </div>

        <div class="form-section" id="sectionAlergiaInput" style="display: none;">
            <div class="dynamic-block">
                <span>Alergias a medicamentos</span> <i class="bi bi-plus-circle-fill"></i>
            </div>
            <div class="form-row">
                <div class="form-group-custom c-3">
                    <label>Medicamento</label>
                    <select class="form-input-custom">
                        <option value="Losartana">Losartana</option>
                    </select>
                </div>
                <div class="form-group-custom c-5">
                    <label>Descrição</label>
                    <input type="text" class="form-input-custom" value="Não consegue levantar o braço esquerdo." />
                </div>
            </div>
        </div>

        <div class="form-section" id="sectionDeficienciaInput">
            <div class="dynamic-block">
                <span>Deficiências</span> <i class="bi bi-plus-circle-fill"></i>
            </div>
            <div class="form-row">
                <div class="form-group-custom c-5">
                    <label>Descrição</label>
                    <input type="text" class="form-input-custom" value="Não consegue levantar o braço esquerdo." />
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="section-title">
                <i class="bi bi-geo-alt-fill"></i> Endereço
            </div>
            <div class="form-row">
                <div class="form-group-custom c-2">
                    <label asp-for="Cep">Cep</label>
                    <input asp-for="Cep" class="form-input-custom" required />
                    <span asp-validation-for="Cep" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
                <div class="form-group-custom c-5">
                    <label asp-for="Rua">Rua</label>
                    <input asp-for="Rua" class="form-input-custom" required />
                    <span asp-validation-for="Rua" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
                <div class="form-group-custom c-5">
                    <label asp-for="Bairro">Bairro</label>
                    <input asp-for="Bairro" class="form-input-custom" required />
                    <span asp-validation-for="Bairro" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
            </div>
            <div class="form-row">
                <div class="form-group-custom c-1">
                    <label asp-for="Identificador">Identificador</label>
                    <input asp-for="Identificador" class="form-input-custom" required />
                    <span asp-validation-for="Identificador" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
                <div class="form-group-custom c-4">
                    <label asp-for="Cidade">Cidade</label>
                    <input asp-for="Cidade" class="form-input-custom" required />
                    <span asp-validation-for="Cidade" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>

                <div class="form-group-custom c-3">
                    <label asp-for="Bairro">Bairro</label>
                    <input asp-for="Bairro" class="form-input-custom" required />
                    <span asp-validation-for="Bairro" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
                <div class="form-group-custom c-2">
                    <label asp-for="Estado">Estado</label>
                    <select asp-for="Estado" class="form-input-custom" asp-items="Html.GetEnumSelectList<EstadoBr>()" required>
                        <option value="">Selecionar</option>
                    </select>
                    <span asp-validation-for="Estado" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
                <div class="form-group-custom c-5">
                    <label asp-for="Complemento">Complemento</label>
                    <input asp-for="Complemento" class="form-input-custom" required />
                    <span asp-validation-for="Complemento" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
            </div>
        </div>

        <div class="form-section">
            <div class="section-title">
                <i class="bi bi-phone-fill"></i> Contato
            </div>
            <div class="form-row">
                <div class="form-group-custom c-1">
                    <label asp-for="Ddd">DDD</label>
                    <input asp-for="Ddd" class="form-input-custom" required />
                    <span asp-validation-for="Ddd" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
                <div class="form-group-custom c-3">
                    <label asp-for="Telefone">Telefone</label>
                    <input asp-for="Telefone" class="form-input-custom" required />
                    <span asp-validation-for="Telefone" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
            </div>

            <div style="color: #5c677d; font-size: 13px; font-weight: 600; margin: 15px 0 10px 0;">
                <i class="bi bi-chevron-down"></i> Contato do responsável
            </div>

            <div class="form-row">
                <div class="form-group-custom c-1">
                    <label asp-for="DddResponsavel">DDD</label>
                    <input asp-for="DddResponsavel" class="form-input-custom" />
                    <span asp-validation-for="DddResponsavel" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
                <div class="form-group-custom c-3">
                    <label asp-for="TelefoneResponsavel">Telefone</label>
                    <input asp-for="TelefoneResponsavel" class="form-input-custom" />
                    <span asp-validation-for="TelefoneResponsavel" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
                <div class="form-group-custom c-6">
                    <label asp-for="NomeTelefoneResponsavel">Responsável</label>
                    <input asp-for="NomeTelefoneResponsavel" class="form-input-custom" />
                    <span asp-validation-for="NomeTelefoneResponsavel" class="text-danger" style="font-size: 13px; display: block; margin-top: 5px;"></span>
                </div>
            </div>
        </div>

        <div class="footer-buttons">
            <a asp-action="Index" class="btn-cancelar">Cancelar</a>
            <button type="submit" class="btn-salvar-azul">Salvar</button>
        </div>

    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<script>
    function toggleAlergiaBlock() {
        var chk = document.getElementById('switchAlergia');
        var txt = document.getElementById('txtAlergia');
        var block = document.getElementById('sectionAlergiaInput');
        var hiddenInput = document.getElementById('AlergiaMedicamentoHidden');

        if(chk.checked) {
            txt.innerText = "Sim";
            block.style.display = "block";
            hiddenInput.value = "1"; // Envia 1 (Sim) para o C#
        } else {
            txt.innerText = "Não";
            block.style.display = "none";
            hiddenInput.value = "0"; // Envia 0 (Não) para o C#
        }
    }

    function toggleDeficienciaBlock() {
        var chk = document.getElementById('switchDeficiencia');
        var txt = document.getElementById('txtDeficiencia');
        var block = document.getElementById('sectionDeficienciaInput');
        var hiddenInput = document.getElementById('PossuiDeficienciaHidden');

        if(chk.checked) {
            txt.innerText = "Sim";
            block.style.display = "block";
            hiddenInput.value = "1"; // Envia 1 (Sim) para o C#
        } else {
            txt.innerText = "Não";
            block.style.display = "none";
            hiddenInput.value = "0"; // Envia 0 (Não) para o C#
        }
    }

    function actualizarNomeFoto(input) {
        if (input.files && input.files[0]) {
            document.getElementById('nomeArquivoFoto').innerText = input.files[0].name;
        }
    }
</script>