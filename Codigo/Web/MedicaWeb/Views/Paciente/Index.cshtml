@using Core.Dto.PacienteDto
@model IEnumerable<PacienteDto>

@{
    ViewData["Title"] = "Pacientes";
}

<div class="calendario-container">
    <div class="table-header">
        <h2 class="titulo-sessao">Pacientes</h2>
        <a asp-controller="Paciente" asp-action="Create" class="btn-novo">Novo</a>
    </div>

    <table id="tabelaPacientes" class="custom-table">
        <thead>
            <tr>
                <th>Nome</th>
                <th>CPF</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                @foreach (var item in Model)
                {
                    <tr onclick="location.href='@Url.Action("Details", "Paciente", new { id = item.Id })'" style="cursor:pointer;">
                        <td class="font-bold">@item.Nome</td>
                        <td>@item.Cpf</td>
                        <td>
                            @if (item.Ativo == "S")
                            {
                                <span>Ativo</span>
                            }
                            else
                            {
                                <span>Inativo</span>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#tabelaPacientes').DataTable({
                "language": {
                    "url": "https://cdn.datatables.net/plug-ins/1.13.6/i18n/pt-BR.json"
                },
                "pageLength": 10,
                "searching": false,
                "info": false,
                "dom": 'rt<"bottom"lp><"clear">',
                "columnDefs": [
                    { "width": "50%", "targets": 0 },
                    { "width": "30%", "targets": 1 },
                    { "width": "20%", "targets": 2 }
                ]
            });
        });
    </script>
}